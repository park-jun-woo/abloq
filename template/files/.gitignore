# Hugo build output
public/
resources/
.hugo_build.lock

# abloq gate caches (citation receipts etc.) — local state; an untracked
# .abloq/ would otherwise trip the queue quests' queue-scope change-set check
.abloq/

# Terraform state
deploy/terraform/.terraform/
deploy/terraform/*.tfstate
deploy/terraform/*.tfstate.backup
deploy/terraform/*.tfvars
