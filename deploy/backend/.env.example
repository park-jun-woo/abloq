# abloqd 셀프호스트 시크릿 템플릿 (Phase019)
#
# 사용: cp .env.example .env 후 값 기입 — .env는 절대 커밋하지 않는다.
# docker compose가 이 파일을 자동으로 읽는다 (compose 파일과 같은 디렉토리).
# 본번 가동 절차·자격증명 체크리스트: docs/operations.md
#
# 규약: 자격증명은 전부 백엔드에만 있다 (설계서 §3.3) — 에이전트·영수증·
# 큐 파일에는 절대 들어가지 않는다. cron 서비스 시크릿은 operator
# 자격증명(토큰 아님): access token TTL 15분이라 토큰 보관은 곧 401이다.

# 멀티사이트 (Phase020, v0.2.0): 사이트가 2개 이상이면 아래 "사이트 단위"
# env 8종(BLOG_REPO_PATH, QUEUE_EXPORT_REPO_URL·AUTHOR·AUTHOR_EMAIL,
# GSC_SITE_URL, GSC_SA_JSON_PATH, CF_LOG_SOURCE, INDEXNOW_KEY)을
# deploy/backend/sites.yaml 의 사이트 행으로 이관하고 compose의
# SITES_YAML_PATH 주석을 해제한다 (cp sites.yaml.example sites.yaml).
# 하위호환: SITES_YAML_PATH 없이 BLOG_REPO_PATH만 있으면 기동 시
# name=default 사이트 1개가 이 env들로 합성된다 — 단, API 경로는
# /sites/default/… 다 (docs/operations.md §5.2).

# ── 필수 ──────────────────────────────────────────────────────────────
# postgres 비밀번호 (compose가 DATABASE_URL을 조립한다)
POSTGRES_PASSWORD=
# JWT 서명 시크릿 — 32자 이상 (예: openssl rand -hex 32)
JWT_SECRET=
# 블로그 저장소의 호스트 경로 (ro 마운트 — blog.yaml과 content/를 읽는다)
BLOG_REPO_PATH=

# ── 선택: 포트/DB 이름/로그 ───────────────────────────────────────────
#ABLOQD_PORT=8080
#POSTGRES_DB=abloqd
#POSTGRES_USER=abloqd
#LOG_LEVEL=info

# ── cron 프로필 공통 (backstop/crawl/gsc/citation/report/freshness/evidence/cluster/queue) ──
# operator 계정 — 매 주기 login으로 토큰을 새로 발급받는다.
# 비밀번호에 큰따옴표(")와 백슬래시(\)는 금지 — cron 스크립트와 CI 훅이
# 비밀번호를 JSON body에 그대로 끼워 넣는다 (그 외 특수문자는 무관,
# backend/scripts/compose-cron-smoke가 검증).
ABLOQD_OPERATOR_EMAIL=
ABLOQD_OPERATOR_PASSWORD=
# 주기 오버라이드 (초). 기본값: backstop 900, crawl/gsc 86400(일간),
# citation 604800(주간), report 2592000(월간), freshness 2592000(월간),
# evidence/cluster 7776000(분기), queue 604800(주간).
#BACKSTOP_PERIOD_SECONDS=900
#CRAWL_PERIOD_SECONDS=86400
#GSC_PERIOD_SECONDS=86400
#CITATION_PERIOD_SECONDS=604800
#REPORT_PERIOD_SECONDS=2592000
#FRESHNESS_PERIOD_SECONDS=2592000
#EVIDENCE_PERIOD_SECONDS=7776000
#CLUSTER_PERIOD_SECONDS=7776000
#QUEUE_EXPORT_PERIOD_SECONDS=604800

# ── 아카이버 (Phase008) — 비우면 해당 kind 영수증이 failed로 남는다 ──
# IndexNow 키 (사이트 루트의 <key>.txt와 일치해야 한다)
INDEXNOW_KEY=
# GSC 서비스 계정 JSON의 호스트 경로 (ro 마운트, indexing+webmasters.readonly scope)
GSC_SA_JSON_FILE=
# Wayback SPN2 S3-style 키 쌍 (https://archive.org/account/s3.php)
WAYBACK_ACCESS_KEY=
WAYBACK_SECRET_KEY=
#GSC_DAILY_QUOTA=200

# ── 큐 exporter + 리포트 발행 (Phase009·014) ─────────────────────────
# 블로그 저장소의 push 가능한 origin (ssh URL이면 deploy key 필요)
QUEUE_EXPORT_REPO_URL=
# 쓰기 권한 deploy key + known_hosts의 호스트 경로 (ssh origin일 때만)
QUEUE_DEPLOY_KEY_FILE=
QUEUE_KNOWN_HOSTS_FILE=
#QUEUE_EXPORT_AUTHOR=abloqd-bot
#QUEUE_EXPORT_AUTHOR_EMAIL=abloqd-bot@abloq.local

# ── 크롤 수집 (Phase012) — CF 로그 → crawl_hits ──────────────────────
# 로컬 디렉토리 또는 s3://bucket/prefix (비우면 POST /ingest/crawl이 500)
CF_LOG_SOURCE=
# S3 소스일 때만: 로그 버킷 읽기 전용(RO) IAM 자격
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
#AWS_SESSION_TOKEN=
#CF_LOG_MARGIN_HOURS=2

# ── GSC 폴링 (Phase013) — SA 자격은 아카이버와 공유(GSC_SA_JSON_FILE) ──
# 비우면 blog.yaml baseURL을 URL-prefix 속성으로 사용
#GSC_SITE_URL=
#GSC_DELAY_MARGIN_DAYS=2
#GSC_LOOKBACK_DAYS=28
#GSC_INSPECT_RECENT_DAYS=7
#GSC_INSPECT_MAX=10

# ── 인용 샘플링 (Phase013) — 키가 있는 엔진만 돈다(옵트인) ────────────
# 비용 상한은 blog.yaml geo.citation_budget (기본 0 = 비활성)
#PERPLEXITY_API_KEY=
#OPENAI_API_KEY=
#ANTHROPIC_API_KEY=
#CITATION_INTERVAL_MS=1000
